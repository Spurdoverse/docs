{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Spurdoverse",
  "colors": {
    "primary": "#E4733F",
    "light": "#E4733F",
    "dark": "#E4733F"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#F3F4F6",
      "dark": "#0A0A0A"
    }
  },
  "fonts": {
    "family": "Geist"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Learn",
        "groups": [
          {
            "group": "Learn",
            "pages": [
              "learn/building-esp"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/globals",
              "api/wasm"
            ]
          },
          {
            "group": "Modules",
            "pages": [
              "api/math",
              "api/render",
              "api/game",
              "api/ffi",
              "api/fs",
              "api/memory",
              "api/entities",
              "api/input",
              "api/convars",
              "api/trace",
              "api/localStorage"
            ]
          },
          {
            "group": "Types",
            "pages": [
              "api/types/vector",
              "api/types/vector2",
              "api/types/qangle",
              "api/types/color",
              "api/types/texture",
              "api/types/pointer"
            ]
          }

        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://spurdoverse.app"
      }
    ]
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity"
   ]
  },
  "footer": {}
}
